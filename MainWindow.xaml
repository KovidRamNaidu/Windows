<Window x:Class="SnapPickWin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:SnapPickWin.ViewModels"
        xmlns:converters="clr-namespace:SnapPickWin.Utils"
        mc:Ignorable="d"
        Title="SnapPick - Photographer Hub" Height="700" Width="1100"
        Background="#121212" WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <converters:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:NotNullToVisibilityConverter x:Key="NotNullToVisibilityConverter"/>
        <converters:PathToFilenameConverter x:Key="PathToFilenameConverter"/>

        <!-- Font Styles -->
        <FontFamily x:Key="Outfit">Segoe UI, Arial, sans-serif</FontFamily>

        <!-- Glassmorphism Styles -->
        <Style x:Key="GlassBorder" TargetType="Border">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#2D2D2D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="15" ShadowDepth="3" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Text Box Styling -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="SelectionBrush" Value="#8A2BE2"/>
            <Setter Property="FontFamily" Value="{StaticResource Outfit}"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="SelectionBrush" Value="#8A2BE2"/>
        </Style>

        <!-- Button Styling -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#8A2BE2"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="{StaticResource Outfit}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Glass Panel Style -->
        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="15"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Background Gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F0F1A" Offset="0"/>
                <GradientStop Color="#1A0D2A" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <!-- Left Navigation Pane -->
            <ColumnDefinition Width="220"/>
            <!-- Main Content Area -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation Pane -->
        <Border Grid.Column="0" Background="#14141E" BorderBrush="#22222E" BorderThickness="0,0,1,0">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Brand Header -->
                <StackPanel Grid.Row="0" Margin="0,10,0,30">
                    <TextBlock Text="SnapPick" FontSize="26" FontWeight="Bold" Foreground="#FFFFFF" FontFamily="{StaticResource Outfit}"/>
                    <TextBlock Text="Photographer Hub" FontSize="12" Foreground="#888899" Margin="0,5,0,0" FontFamily="{StaticResource Outfit}"/>
                </StackPanel>

                <!-- Sidebar Buttons -->
                <StackPanel Grid.Row="1" VerticalAlignment="Top">
                    <Button Content="My Projects" Background="Transparent" Foreground="#FFFFFF" FontSize="14" HorizontalAlignment="Left" Margin="0,5" Command="{Binding NavigateToProjectsCommand}" Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <TextBlock Text="Logged in as:" Foreground="#888899" FontSize="11" Margin="0,15,0,5" Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding UserEmail}" Foreground="#FFFFFF" FontSize="12" TextTrimming="CharacterEllipsis" Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <!-- Footer Signout Button -->
                <Button Grid.Row="2" Content="Sign Out" Background="#D32F2F" Foreground="#FFFFFF" Margin="0,10" Command="{Binding LogoutCommand}" Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>
        </Border>

        <!-- Main Display Switching Workspace -->
        <Grid Grid.Column="1" Margin="30">
            <ContentControl Content="{Binding CurrentView}">
                <ContentControl.Resources>
                    
                    <!-- 1. LOGIN SCREEN VIEW TEMPLATE -->
                    <DataTemplate DataType="{x:Type x:String}" x:Key="LoginScreenTemplate">
                        <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Border Style="{StaticResource GlassBorder}" Width="380" Padding="30">
                                <StackPanel>
                                    <TextBlock Text="Welcome Partner" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                                    
                                    <StackPanel Margin="0,0,0,15">
                                        <TextBlock Text="Email Address" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,5"/>
                                        <TextBox x:Name="EmailInput" Text="siri@snappick.com"/>
                                    </StackPanel>
                                    
                                    <StackPanel Margin="0,0,0,20">
                                        <TextBlock Text="Password" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,5"/>
                                        <PasswordBox x:Name="PasswordInput"/>
                                    </StackPanel>
                                    
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Sign In" Margin="0,0,5,0" Click="OnLoginClick"/>
                                        <Button Grid.Column="1" Content="Sign Up" Margin="5,0,0,0" Background="#3E2723" Click="OnRegisterClick"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DataTemplate>

                    <!-- 2. PROJECTS SCREEN LIST TEMPLATE -->
                    <DataTemplate DataType="{x:Type x:String}" x:Key="ProjectsScreenTemplate">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="My Project Spaces" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="+ New Project" Background="#8A2BE2" Padding="15,8" Click="OnCreateProjectClick"/>
                            </Grid>

                            <!-- Scrollable Workspace List -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding DataContext.Projects, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource GlassBorder}" Margin="0,0,0,15" Padding="20">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,5"/>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Status}" Foreground="#00FFCC" FontWeight="SemiBold" FontSize="11" Margin="0,0,15,0"/>
                                                            <TextBlock Text="{Binding CreatedAt, StringFormat='Created: {0:g}'}" Foreground="#888888" FontSize="11"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Button Content="Open Space" Background="#3A3A55" Click="OnOpenProjectClick" Margin="0,0,10,0"/>
                                                        <Button Content="Delete" Background="#C62828" Click="OnDeleteProjectClick"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </DataTemplate>

                    <!-- 3. PROJECT GALLERY VIEW MODEL TEMPLATE -->
                    <DataTemplate DataType="{x:Type viewmodels:GalleryViewModel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Back & Header Panel -->
                            <Grid Grid.Row="0" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="← Back" Background="#2A2A3E" Command="{Binding NavigateBackCommand}" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF"/>
                                    <TextBlock Text="{Binding Status, StringFormat='Status: {0}'}" Foreground="#00FFFF" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="Import Photos" Command="{Binding ImportPhotosCommand}" Click="OnImportFolderClick" Visibility="{Binding CanImport, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,10,0"/>
                                    <Button Content="Upload &amp; Activate" Command="{Binding StartUploadPipelineCommand}" Background="#00CC88" Visibility="{Binding CanUpload, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,10,0"/>
                                    <Button Content="Cancel" Command="{Binding CancelUploadCommand}" Background="#C62828" Visibility="{Binding IsUploading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Project Control Panels & Grids -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="250"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Categories List -->
                                <Border Grid.Column="0" Background="#161622" CornerRadius="12" Padding="15" Margin="0,0,20,0" BorderBrush="#22222E" BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="Categories" FontSize="16" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,0,0,15"/>
                                        <ListBox Grid.Row="1" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" Background="Transparent" BorderThickness="0" Foreground="#FFFFFF">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="5,8">
                                                        <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="13"/>
                                                        <TextBlock Text="{Binding PhotoCount, StringFormat=' ({0})'}" Foreground="#888888" FontSize="11" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>

                                <!-- Gallery View & Sync Panel -->
                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Main Photos List -->
                                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding SelectedCategory.ImageReferences}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Margin="5"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#252535" BorderBrush="#353545" BorderThickness="1" CornerRadius="8" Width="110" Height="110" Margin="8" Padding="5">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="*"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <!-- In real WPF app on Windows, we load thumbnails here -->
                                                            <TextBlock Grid.Row="0" Text="{Binding OriginalPath, Converter={StaticResource PathToFilenameConverter}}" Foreground="#FFFFFF" FontSize="10" TextAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                            <TextBlock Grid.Row="1" Text="{Binding Status}" Foreground="#FFCC00" FontSize="9" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <!-- Bottom Action Dashboard (Export & Sync Status) -->
                                    <Border Grid.Row="1" Background="#161622" CornerRadius="12" Padding="20" Margin="0,15,0,0" BorderBrush="#22222E" BorderThickness="1">
                                        <Grid>
                                            <!-- Upload Status Pipeline -->
                                            <StackPanel Visibility="{Binding IsUploading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="{Binding UploadStatusText}" Foreground="#FFFFFF" FontWeight="Medium" Margin="0,0,0,10"/>
                                                <ProgressBar Value="{Binding UploadProgress}" Height="8" Background="#222222" Foreground="#8A2BE2"/>
                                            </StackPanel>

                                            <!-- Active Links and Selections dashboard -->
                                            <Grid Visibility="{Binding IsUploading, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <StackPanel Grid.Column="0">
                                                    <!-- Share token links -->
                                                    <StackPanel Orientation="Horizontal" Visibility="{Binding ShareLink, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" Margin="0,0,0,8">
                                                        <TextBlock Text="Client Link: " Foreground="#888899" FontSize="12" VerticalAlignment="Center"/>
                                                        <TextBox Text="{Binding ShareLink, Mode=OneWay}" IsReadOnly="True" Background="#252535" BorderBrush="Transparent" Foreground="#00FFCC" Padding="5" Width="300" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    
                                                    <!-- Sync dashboard info -->
                                                    <TextBlock Text="Waiting for client selections..." Foreground="#888888" FontSize="12" Visibility="{Binding Project.Selection, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                    <StackPanel Visibility="{Binding Project.Selection, Converter={StaticResource NotNullToVisibilityConverter}}">
                                                        <TextBlock Text="✓ Selection received from client!" Foreground="#00FFCC" FontWeight="Bold" FontSize="13" Margin="0,0,0,5"/>
                                                        <TextBlock Text="{Binding Project.Selection.SubmittedAt, StringFormat='Submitted: {0}'}" Foreground="#888888" FontSize="11" Margin="0,0,0,5"/>
                                                        <TextBlock Text="{Binding Project.Selection.RecheckCount, StringFormat='Recheck Counter: {0}'}" Foreground="#FFCC00" FontSize="11"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                                    <Button Content="Sync Dashboard" Command="{Binding FetchSelectionsCommand}" Background="#5E35B1" Visibility="{Binding ShareLink, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" Margin="0,0,10,0"/>
                                                    <Button Content="Reset Selections" Click="OnResetSelectionsDialogClick" Background="#EF6C00" Visibility="{Binding ShareLink, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" Margin="0,0,10,0"/>
                                                    <Button Content="Export Selected Photos" Click="OnExportSelectedClick" Background="#00838F" Visibility="{Binding Project.Selection, Converter={StaticResource NotNullToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ContentControl.Resources>
                
                <!-- Setup Content Template selectors dynamically based on data types -->
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Style.Triggers>
                            <Trigger Property="Content" Value="LoginScreen">
                                <Setter Property="ContentTemplate" Value="{StaticResource LoginScreenTemplate}"/>
                            </Trigger>
                            <Trigger Property="Content" Value="ProjectsScreen">
                                <Setter Property="ContentTemplate" Value="{StaticResource ProjectsScreenTemplate}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </Grid>
    </Grid>
</Window>
